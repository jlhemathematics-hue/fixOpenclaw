# direnv configuration for fixOpenclaw
# Automatically activates Python 3.13 virtual environment

# Use Python 3.13 from Homebrew
export PYTHON_313=/opt/homebrew/bin/python3.13

# Activate virtual environment if it exists
if [ -d "venv" ]; then
    source venv/bin/activate
    echo "✅ Python 3.13 virtual environment activated"
else
    echo "⚠️  Virtual environment not found. Run ./setup_python313.sh"
fi
